{
  "version": 2,
  "builds": [
    {
      "src": "invoice-harvester-online/server/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/socket.io/(.*)",
      "dest": "invoice-harvester-online/server/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "invoice-harvester-online/server/server.js"
    }
  ]
}
